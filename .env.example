# === Required ===
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# === Optional ===
# CryptoPanic free API key: https://cryptopanic.com/developers/api/
CRYPTOPANIC_KEY=
# CoinGecko demo API key (higher rate limit; not required for free tier)
COINGECKO_API_KEY=

# Public dashboard URL shown in Telegram messages
DASHBOARD_URL=https://<your-username>.github.io/crypto-research-agent/

# === Tuning ===
CLAUDE_MODEL=claude-sonnet-4-6
TOP_N_COINS=500
TOP_K_GAINERS=5
MIN_VOLUME_USD=1000000
NARRATIVE_LOOKBACK_DAYS=7
